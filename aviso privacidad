  </div>

</div><!-- /pp-content -->

<script>
// ── CONFIG ────────────────────────────────────────────────────────────
var SCRIPT_URL_FALLBACK = "https://script.google.com/macros/s/AKfycbwu7VVHC3RgS1fXwOtnh3ebHf4Md9xVmYF8cVZznKekPVEDj79izRcQmECYPH4GLIsG/exec";

function getScriptUrl() {
  try {
    var u = localStorage.getItem("sp_url");
    if (u) return u;
  } catch(e) {}
  return SCRIPT_URL_FALLBACK;
}

function esc(s) {
  return String(s || "").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
}

// ── INIT ──────────────────────────────────────────────────────────────
(function init() {
  var params = new URLSearchParams(window.location.search);
  var lic = params.get("lic") || "";

  if (!lic) {
    mostrarError("Falta el parámetro ?lic= en la URL.");
    return;
  }

  fetch(getScriptUrl() + "?action=getCfgPublica&lic=" + encodeURIComponent(lic))
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!data.ok) { mostrarError(data.msg || "Consultorio no encontrado."); return; }
      renderAviso(data.cfg, lic);
    })
    .catch(function() {
      mostrarError("No se pudo conectar con el servidor. Verifica tu conexión.");
    });
})();

// ── RENDER ────────────────────────────────────────────────────────────
function renderAviso(cfg, lic) {
  // Datos del médico
  var prefijo  = cfg.prefijo || "";
  var nombre   = cfg.nombre_com || cfg.nombre_legal || "Médico";
  var display  = prefijo ? prefijo + " " + nombre : nombre;
  var esp      = cfg.especialidad_txt || cfg.especialidad || "";
  var espMap   = { medico:"Medicina General", dentista:"Odontología", psicologo:"Psicología", quiropractico:"Quiropráctica", nutriologo:"Nutriología" };
  var espTxt   = espMap[esp] || esp;
  var cedula   = cfg.cedula || "";
  var tel      = cfg.telefono || "";
  var dir      = cfg.direccion || "";

  // Nombre de la plataforma — viene del campo nombre_generador via scriptUrl/cfg
  // El backend lo inyecta en cfg como "plataforma" o lo leemos de nombre_generador
  // En getCfgPublica el script devuelve cfg.nombre_legal del generador o usamos fallback
  var plataforma = cfg.plataforma || "Consultas Saludables Pro";

  var anio = new Date().getFullYear();
  var urlConsultorio = window.location.origin + window.location.pathname.replace("aviso_privacidad.html","") + "consultorio_v4.html?lic=" + lic;

  // ── HEAD / TITLE ──
  document.getElementById("page-title").textContent = "Aviso de Privacidad — " + display;

  // ── HEADER ──
  setText("hdr-plat", plataforma);
  setText("hdr-slug", "Consultorio: " + lic);
  setText("hdr-anio", String(anio));

  // ── LINK BACK ──
  var linkBack = document.getElementById("link-back");
  linkBack.href = "consultorio_v4.html?lic=" + encodeURIComponent(lic);
  linkBack.textContent = "← Volver al consultorio de " + display;

  // ── AVATAR ──
  var avatarEl = document.getElementById("resp-avatar");
  if (cfg.logo && cfg.logo.length > 100) {
    avatarEl.innerHTML = '<img src="' + cfg.logo + '" alt="Logo"/>';
  } else {
    var partes = nombre.split(" ");
    avatarEl.textContent = ((partes[0]||"")[0]||"").toUpperCase() + ((partes[1]||"")[0]||"").toUpperCase();
  }

  // ── CARD MÉDICO ──
  setText("resp-nombre", display);
  setText("resp-esp", espTxt);
  setText("card-plat", plataforma);
  setChip("chip-cedula", cedula ? "Céd. " + cedula : "");
  setChip("chip-tel", tel ? "☎ " + tel : "");
  setChip("chip-slug", lic);

  // ── TABLA SECCIÓN 1 ──
  setText("tbl-nombre", display);
  setText("tbl-esp", espTxt || "—");
  setText("tbl-cedula", cedula || "—");
  setText("tbl-tel", tel || "—");
  setText("tbl-dir", dir || "—");
  document.getElementById("tbl-url").innerHTML = '<a href="' + esc(urlConsultorio) + '" target="_blank">' + esc(urlConsultorio) + '</a>';
  setText("tbl-plat", plataforma);
  setText("s1-plat", plataforma);

  // ── TOKEN EJEMPLO ──
  setText("token-ejemplo", lic + "_a1b2c3");

  // ── CONTACTO / FOOTER ──
  setText("contact-plat", plataforma);
  setText("footer-plat", "© " + anio + " " + plataforma);

  // ── MOSTRAR ──
  document.getElementById("pp-loading").style.display = "none";
  document.getElementById("pp-content").style.display = "block";
}

function setText(id, val) {
  var el = document.getElementById(id);
  if (el) el.textContent = val;
}

function setChip(id, val) {
  var el = document.getElementById(id);
  if (!el) return;
  if (val) { el.textContent = val; el.style.display = "inline-block"; }
  else     { el.style.display = "none"; }
}

function mostrarError(msg) {
  document.getElementById("pp-loading").style.display = "none";
  document.getElementById("pp-error").style.display = "flex";
  document.getElementById("pp-error-msg").textContent = msg;
}
</script>
</body>
</html>
