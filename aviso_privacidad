<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<title>Aviso de Privacidad</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --p:#1A7FC1;--p2:#38BDF8;
  --bg:#F8FAFC;--card:#fff;--card2:#F0F6FF;
  --border:#D1DDE8;--border2:#E8F0F8;
  --txt:#0D1520;--txt2:#4A6A85;--txt3:#8AAABF;
  --ff:'DM Sans',sans-serif;--r:14px;--rs:8px;
}
body{font-family:var(--ff);background:var(--bg);color:var(--txt);min-height:100vh;font-size:15px;line-height:1.7}
a{color:var(--p);text-decoration:none}
a:hover{text-decoration:underline}

/* ── TOPBAR ── */
.topbar{position:sticky;top:0;z-index:50;background:rgba(255,255,255,.95);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 20px;height:56px;gap:12px}
.logo{font-size:16px;font-weight:700;color:var(--p);letter-spacing:-.3px;cursor:pointer;display:flex;align-items:center;gap:8px}
.logo-img{width:32px;height:32px;border-radius:50%;object-fit:cover;display:none}
.back-btn{display:inline-flex;align-items:center;gap:6px;font-size:13px;color:var(--txt2);background:var(--card2);border:1px solid var(--border);padding:5px 12px;border-radius:99px;cursor:pointer;transition:.15s;margin-left:auto}
.back-btn:hover{background:var(--border)}

/* ── HERO ── */
.hero{background:linear-gradient(135deg,#0D2137 0%,#0A3A5C 50%,#0D2137 100%);color:#fff;padding:48px 24px 40px;text-align:center}
.hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.85);padding:4px 14px;border-radius:99px;font-size:12px;font-weight:600;letter-spacing:.5px;margin-bottom:16px}
.hero-title{font-size:clamp(22px,4vw,32px);font-weight:700;margin-bottom:8px}
.hero-sub{font-size:14px;color:rgba(255,255,255,.6);max-width:500px;margin:0 auto 20px}
.hero-chips{display:flex;flex-wrap:wrap;justify-content:center;gap:8px}
.hero-chip{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);color:rgba(255,255,255,.8);padding:5px 14px;border-radius:99px;font-size:12px;font-weight:500}
.hero-chip b{color:#fff}

/* ── CONTENIDO ── */
.wrap{max-width:760px;margin:0 auto;padding:32px 20px 64px}
.sec{background:var(--card);border:1px solid var(--border);border-radius:var(--r);margin-bottom:20px;overflow:hidden;box-shadow:0 2px 8px rgba(13,33,55,.05)}
.sec-hdr{padding:16px 20px;background:var(--card2);border-bottom:1px solid var(--border2);display:flex;align-items:center;gap:10px}
.sec-num{width:26px;height:26px;border-radius:50%;background:var(--p);color:#fff;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.sec-title{font-size:15px;font-weight:700;color:var(--txt)}
.sec-body{padding:20px}
p{color:var(--txt2);margin-bottom:12px;font-size:14px}
p:last-child{margin-bottom:0}

/* ── TABLAS ── */
.tbl-wrap{overflow-x:auto;border-radius:var(--rs);border:1px solid var(--border);margin-top:8px}
table{width:100%;border-collapse:collapse;font-size:13px}
th{background:var(--card2);color:var(--txt);font-weight:700;text-align:left;padding:10px 14px;border-bottom:1px solid var(--border)}
td{padding:10px 14px;color:var(--txt2);border-bottom:1px solid var(--border2);vertical-align:top}
tr:last-child td{border-bottom:none}
td:first-child{color:var(--txt);font-weight:600;white-space:nowrap;width:35%}
.badge-ok{display:inline-flex;align-items:center;gap:4px;background:rgba(22,163,74,.1);color:#166534;border:1px solid rgba(22,163,74,.25);padding:2px 9px;border-radius:99px;font-size:11px;font-weight:700}

/* ── LISTA DE DERECHOS ── */
.rights-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:10px;margin-top:8px}
.right-card{background:var(--card2);border:1px solid var(--border2);border-radius:var(--rs);padding:12px 14px}
.right-card-icon{font-size:20px;margin-bottom:4px}
.right-card-title{font-size:13px;font-weight:700;color:var(--txt);margin-bottom:2px}
.right-card-desc{font-size:11px;color:var(--txt2)}

/* ── SECCIÓN CONTACTO GENERADOR ── */
.gen-cta{background:linear-gradient(135deg,#0D2137,#0A3A5C);border-radius:var(--r);padding:28px 24px;text-align:center;margin-top:32px;color:#fff}
.gen-cta-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.1);border:1px solid rgba(255,255,255,.2);color:rgba(255,255,255,.8);padding:3px 12px;border-radius:99px;font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;margin-bottom:12px}
.gen-cta-avatar{width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,var(--p),var(--p2));display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;color:#fff;margin:0 auto 10px;overflow:hidden;border:3px solid rgba(255,255,255,.2)}
.gen-cta-avatar img{width:100%;height:100%;object-fit:cover;border-radius:50%}
.gen-cta-nombre{font-size:18px;font-weight:700;margin-bottom:4px}
.gen-cta-desc{font-size:13px;color:rgba(255,255,255,.65);margin-bottom:20px;max-width:400px;margin-left:auto;margin-right:auto}
.gen-cta-btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.gen-btn-wa{display:inline-flex;align-items:center;gap:8px;background:#22C55E;color:#fff;padding:10px 22px;border-radius:99px;font-size:14px;font-weight:700;cursor:pointer;border:none;transition:.2s;text-decoration:none}
.gen-btn-wa:hover{background:#16A34A;transform:translateY(-1px);text-decoration:none;color:#fff}
.gen-btn-mail{display:inline-flex;align-items:center;gap:8px;background:rgba(255,255,255,.12);color:#fff;padding:10px 22px;border-radius:99px;font-size:14px;font-weight:700;cursor:pointer;border:1px solid rgba(255,255,255,.2);transition:.2s;text-decoration:none}
.gen-btn-mail:hover{background:rgba(255,255,255,.2);transform:translateY(-1px);text-decoration:none;color:#fff}
.gen-cta-disclaimer{font-size:11px;color:rgba(255,255,255,.4);margin-top:14px}

/* ── FOOTER ── */
.footer{background:var(--card);border-top:1px solid var(--border);padding:20px 24px;text-align:center}
.footer-logo{font-size:14px;font-weight:700;color:var(--p);margin-bottom:4px}
.footer-sub{font-size:12px;color:var(--txt3)}

/* ── LOADER ── */
#loader{position:fixed;inset:0;background:var(--bg);z-index:100;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px}
.loader-logo{font-size:22px;font-weight:700;color:var(--p)}
.loader-bar{width:120px;height:3px;background:var(--border);border-radius:99px;overflow:hidden}
.loader-fill{height:100%;background:linear-gradient(90deg,var(--p),var(--p2));animation:fill .8s ease forwards}
@keyframes fill{from{width:0}to{width:100%}}
#main{display:none}

@media(max-width:540px){
  .hero{padding:32px 16px 28px}
  .wrap{padding:20px 12px 48px}
  .rights-grid{grid-template-columns:1fr 1fr}
  td:first-child{white-space:normal}
}
</style>
</head>
<body>

<!-- LOADER -->
<div id="loader">
  <div class="loader-logo" id="loader-logo">Cargando...</div>
  <div class="loader-bar"><div class="loader-fill"></div></div>
</div>

<!-- MAIN -->
<div id="main">

  <!-- TOPBAR -->
  <div class="topbar">
    <div class="logo" onclick="volverConsultorio()">
      <img class="logo-img" id="nav-logo-img" src="" alt="Logo"/>
      <span id="nav-logo-txt">—</span>
    </div>
    <button class="back-btn" onclick="volverConsultorio()">← Volver al consultorio</button>
  </div>

  <!-- HERO -->
  <div class="hero">
    <div class="hero-badge">📋 Documento legal</div>
    <h1 class="hero-title">Aviso de Privacidad</h1>
    <p class="hero-sub" id="hero-sub">Cargando información del consultorio...</p>
    <div class="hero-chips" id="hero-chips"></div>
  </div>

  <!-- CONTENIDO -->
  <div class="wrap">

    <!-- 1. RESPONSABLE DEL TRATAMIENTO -->
    <div class="sec">
      <div class="sec-hdr">
        <div class="sec-num">1</div>
        <div class="sec-title">Responsable del Tratamiento de Datos Personales</div>
      </div>
      <div class="sec-body">
        <p>En cumplimiento con la Ley Federal de Protección de Datos Personales en Posesión de los Particulares (LFPDPPP), se identifica al responsable del tratamiento:</p>
        <div class="tbl-wrap">
          <table>
            <tr><th colspan="2">Datos del Responsable</th></tr>
            <tr><td>Nombre / Razón social</td><td id="tbl-nombre">—</td></tr>
            <tr><td>Especialidad</td><td id="tbl-esp">—</td></tr>
            <tr><td>Cédula profesional</td><td id="tbl-cedula">—</td></tr>
            <tr><td>Teléfono de contacto</td><td id="tbl-tel">—</td></tr>
            <tr><td>Dirección del consultorio</td><td id="tbl-dir">—</td></tr>
            <tr><td>Horario de atención</td><td id="tbl-horario">—</td></tr>
            <tr><td>Verificación</td><td><span class="badge-ok" id="tbl-verificado">● Consultorio verificado</span></td></tr>
          </table>
        </div>

        <div style="margin-top:20px;padding:16px;background:var(--card2);border:1px solid var(--border2);border-radius:var(--rs)">
          <div style="font-size:12px;font-weight:700;color:var(--txt3);letter-spacing:.5px;text-transform:uppercase;margin-bottom:10px">Plataforma tecnológica responsable del sistema</div>
          <div class="tbl-wrap" style="margin-top:0">
            <table>
              <tr><td>Plataforma</td><td id="tbl-plat">—</td></tr>
              <tr><td>Correo de privacidad</td><td id="tbl-correo-priv">—</td></tr>
              <tr><td>Teléfono</td><td id="tbl-plat-tel">—</td></tr>
              <tr><td>Vigencia del aviso</td><td id="tbl-vigencia">—</td></tr>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- 2. DATOS QUE SE RECABAN -->
    <div class="sec">
      <div class="sec-hdr">
        <div class="sec-num">2</div>
        <div class="sec-title">Datos Personales que se Recaban</div>
      </div>
      <div class="sec-body">
        <p>Para las finalidades descritas en este aviso, se recaban las siguientes categorías de datos:</p>
        <div class="tbl-wrap">
          <table>
            <tr><th>Categoría</th><th>Datos específicos</th><th>Finalidad</th></tr>
            <tr><td>Identificación</td><td>Nombre completo, fecha de nacimiento, sexo</td><td>Identificar al paciente</td></tr>
            <tr><td>Contacto</td><td>Teléfono, correo electrónico</td><td>Confirmación y recordatorio de citas</td></tr>
            <tr><td>Motivo de consulta</td><td>Descripción breve proporcionada por el paciente</td><td>Preparar la atención médica</td></tr>
            <tr><td>Historial de citas</td><td>Fechas, horarios, estado de la cita</td><td>Gestión del consultorio</td></tr>
          </table>
        </div>
        <p style="margin-top:14px;font-size:13px;background:#FEF9C3;border:1px solid #FDE68A;border-radius:var(--rs);padding:10px 14px;color:#78350F">
          ⚠️ <strong>No se recaban datos sensibles</strong> (diagnósticos, expediente clínico, datos genéticos) a través de esta plataforma digital. Dichos datos son tratados exclusivamente por el profesional de salud bajo sus propios esquemas de confidencialidad.
        </p>
      </div>
    </div>

    <!-- 3. FINALIDADES -->
    <div class="sec">
      <div class="sec-hdr">
        <div class="sec-num">3</div>
        <div class="sec-title">Finalidades del Tratamiento</div>
      </div>
      <div class="sec-body">
        <p><strong>Finalidades primarias</strong> (necesarias para la prestación del servicio):</p>
        <ul style="padding-left:20px;color:var(--txt2);font-size:14px;margin-bottom:14px">
          <li style="margin-bottom:6px">Gestionar y confirmar solicitudes de cita médica</li>
          <li style="margin-bottom:6px">Enviar recordatorios de cita por los medios proporcionados</li>
          <li style="margin-bottom:6px">Facilitar la comunicación entre paciente y profesional de salud</li>
          <li style="margin-bottom:6px">Administrar el historial de citas del consultorio</li>
        </ul>
        <p><strong>Finalidades secundarias</strong> (sujetas a consentimiento expreso):</p>
        <ul style="padding-left:20px;color:var(--txt2);font-size:14px">
          <li style="margin-bottom:6px">Envío de información sobre servicios del consultorio</li>
          <li style="margin-bottom:6px">Encuestas de satisfacción de la atención recibida</li>
        </ul>
        <p style="margin-top:14px;font-size:13px;color:var(--txt3)">Si no desea que sus datos sean utilizados para finalidades secundarias, puede manifestarlo enviando un correo al responsable indicado en la sección 1 de este aviso.</p>
      </div>
    </div>

    <!-- 4. TRANSFERENCIAS -->
    <div class="sec">
      <div class="sec-hdr">
        <div class="sec-num">4</div>
        <div class="sec-title">Transferencia de Datos</div>
      </div>
      <div class="sec-body">
        <p>Sus datos personales <strong>no serán transferidos a terceros</strong> sin su consentimiento, salvo en los casos previstos en el artículo 37 de la LFPDPPP, que incluyen:</p>
        <ul style="padding-left:20px;color:var(--txt2);font-size:14px">
          <li style="margin-bottom:6px">Cuando la transferencia sea necesaria para la prevención o diagnóstico médico</li>
          <li style="margin-bottom:6px">Cuando sea requerida por autoridades competentes en ejercicio de sus atribuciones</li>
          <li style="margin-bottom:6px">Cuando sea necesaria para cumplir obligaciones legales del responsable</li>
        </ul>
        <p style="margin-top:14px">La plataforma tecnológica utiliza infraestructura de <strong>Google (Google Sheets, Google Apps Script)</strong> para el almacenamiento y procesamiento de datos, sujeta a las políticas de privacidad de Google LLC.</p>
      </div>
    </div>

    <!-- 5. DERECHOS ARCO -->
    <div class="sec">
      <div class="sec-hdr">
        <div class="sec-num">5</div>
        <div class="sec-title">Derechos ARCO</div>
      </div>
      <div class="sec-body">
        <p>Usted tiene derecho a <strong>Acceder, Rectificar, Cancelar y Oponerse</strong> al tratamiento de sus datos personales:</p>
        <div class="rights-grid">
          <div class="right-card">
            <div class="right-card-icon">🔍</div>
            <div class="right-card-title">Acceso</div>
            <div class="right-card-desc">Conocer qué datos tenemos sobre usted y cómo los usamos</div>
          </div>
          <div class="right-card">
            <div class="right-card-icon">✏️</div>
            <div class="right-card-title">Rectificación</div>
            <div class="right-card-desc">Corregir datos inexactos o incompletos</div>
          </div>
          <div class="right-card">
            <div class="right-card-icon">🗑️</div>
            <div class="right-card-title">Cancelación</div>
            <div class="right-card-desc">Solicitar la eliminación de sus datos cuando sea procedente</div>
          </div>
          <div class="right-card">
            <div class="right-card-icon">🚫</div>
            <div class="right-card-title">Oposición</div>
            <div class="right-card-desc">Oponerse al uso de sus datos para finalidades específicas</div>
          </div>
        </div>
        <p style="margin-top:16px;font-size:13px">Para ejercer sus derechos ARCO, envíe una solicitud por escrito al responsable indicado en la <strong>Sección 1</strong>, incluyendo: nombre completo, descripción del derecho a ejercer y cualquier documento que facilite la localización de sus datos. El plazo de respuesta es de <strong>20 días hábiles</strong>.</p>
      </div>
    </div>

    <!-- 6. SEGURIDAD -->
    <div class="sec">
      <div class="sec-hdr">
        <div class="sec-num">6</div>
        <div class="sec-title">Medidas de Seguridad</div>
      </div>
      <div class="sec-body">
        <p>Se han implementado las siguientes medidas de seguridad técnicas, administrativas y físicas para proteger sus datos personales contra daño, pérdida, alteración, destrucción o uso no autorizado:</p>
        <ul style="padding-left:20px;color:var(--txt2);font-size:14px">
          <li style="margin-bottom:6px">Transmisión cifrada mediante HTTPS/TLS</li>
          <li style="margin-bottom:6px">Acceso restringido mediante autenticación por contraseña</li>
          <li style="margin-bottom:6px">Almacenamiento en infraestructura segura de Google Cloud</li>
          <li style="margin-bottom:6px">Control de acceso por roles (solo el profesional de salud responsable puede ver sus datos)</li>
          <li style="margin-bottom:6px">Registro de accesos y modificaciones</li>
        </ul>
      </div>
    </div>

    <!-- 7. CAMBIOS AL AVISO -->
    <div class="sec">
      <div class="sec-hdr">
        <div class="sec-num">7</div>
        <div class="sec-title">Cambios al Aviso de Privacidad</div>
      </div>
      <div class="sec-body">
        <p>Cualquier cambio sustancial al presente aviso de privacidad será comunicado a través de la página del consultorio y/o por los medios de contacto registrados. La versión vigente siempre estará disponible en esta dirección.</p>
        <p>Al proporcionar sus datos personales para solicitar una cita, usted manifiesta haber leído, entendido y aceptado el presente aviso de privacidad.</p>
        <p style="font-size:13px;color:var(--txt3)" id="fecha-actualizacion">Última actualización: —</p>
      </div>
    </div>

    <!-- CTA GENERADOR — Contacto para nuevos consultorios -->
    <div class="gen-cta" id="gen-cta" style="display:none">
      <div class="gen-cta-badge">✨ Plataforma digital médica</div>
      <div class="gen-cta-avatar" id="gen-cta-avatar">?</div>
      <div class="gen-cta-nombre" id="gen-cta-nombre">—</div>
      <div class="gen-cta-desc">¿Eres profesional de la salud y quieres tu propio consultorio digital con sistema de citas? Contáctanos.</div>
      <div class="gen-cta-btns">
        <a class="gen-btn-wa" id="gen-btn-wa" href="#" target="_blank" rel="noopener">💬 WhatsApp</a>
        <a class="gen-btn-mail" id="gen-btn-mail" href="#">✉️ Correo</a>
      </div>
      <div class="gen-cta-disclaimer" id="gen-cta-disclaimer">Sistema desarrollado por <span id="gen-cta-nombre-footer">—</span></div>
    </div>

  </div><!-- /wrap -->

  <!-- FOOTER -->
  <div class="footer">
    <div class="footer-logo" id="footer-logo">—</div>
    <div class="footer-sub" id="footer-sub">Plataforma médica verificada · Aviso de Privacidad</div>
  </div>

</div><!-- /main -->

<script>
var SCRIPT_URL = "https://script.google.com/macros/s/AKfycbwu7VVHC3RgS1fXwOtnh3ebHf4Md9xVmYF8cVZznKekPVEDj79izRcQmECYPH4GLIsG/exec";
var LIC = null;
var CFG = {};

// ── UTILS ──
function esc(s){ return String(s||"").replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;"); }
function setText(id,val){ var el=document.getElementById(id); if(el) el.textContent=val||"—"; }
function setHtml(id,val){ var el=document.getElementById(id); if(el) el.innerHTML=val||"—"; }

function volverConsultorio(){
  if(LIC) window.location.href="index.html?lic="+encodeURIComponent(LIC);
  else history.back();
}

// ── INIT ──
window.addEventListener("DOMContentLoaded",function(){
  var params=new URLSearchParams(window.location.search);
  LIC=params.get("lic")||"";
  if(!LIC){ mostrarError("No se especificó el consultorio."); return; }
  cargarAviso();
});

async function cargarAviso(){
  try{
    var url=SCRIPT_URL+"?action=getCfgPublica&lic="+encodeURIComponent(LIC);
    var r=await fetch(url).then(function(res){ return res.json(); });
    if(!r.ok){ mostrarError(r.msg||"Consultorio no encontrado."); return; }
    CFG=r.cfg||{};
    renderAviso(CFG);
  }catch(e){
    mostrarError("Error de conexión: "+e.message);
  }
}

function renderAviso(cfg){
  // ── Nombre de plataforma — siempre desde cfg.plataforma (inyectado por el backend desde LOGIN_GENERADOR) ──
  var plataforma = cfg.plataforma || "";

  // ── Nombre visible del médico ──
  var prefijo     = cfg.prefijo||"";
  var nombreCom   = cfg.nombre_com||cfg.nombre_legal||"";
  var display     = prefijo ? prefijo+" "+nombreCom : nombreCom;
  var especialidad= cfg.especialidad_txt||cfg.especialidad||"Profesional de la salud";
  var cedula      = cfg.cedula||"";
  var telefono    = cfg.telefono||cfg.whatsapp||"";
  var direccion   = cfg.direccion||"";
  var horario     = cfg.horario||"";
  var desde       = cfg.en_plataforma_desde||new Date().getFullYear();

  // ── LOADER → MAIN ──
  document.getElementById("loader").style.display="none";
  document.getElementById("main").style.display="block";

  // ── TOPBAR ──
  setText("nav-logo-txt", plataforma||display);
  if(plataforma){
    // Intentar mostrar logo del generador si viene
    if(cfg.gen_logo&&cfg.gen_logo.length>100){
      var navImg=document.getElementById("nav-logo-img");
      navImg.src=cfg.gen_logo; navImg.style.display="block";
    }
  }

  // ── HERO ──
  document.title = "Aviso de Privacidad — "+(display||plataforma||"Consultorio");
  setText("hero-sub","Consultorio de "+display+" · "+especialidad);
  var chips=[];
  if(desde) chips.push('<div class="hero-chip">📅 En la plataforma desde <b>'+esc(desde)+'</b></div>');
  if(cfg.verificado) chips.push('<div class="hero-chip">✅ <b>Verificado</b></div>');
  if(plataforma) chips.push('<div class="hero-chip">🏥 <b>'+esc(plataforma)+'</b></div>');
  document.getElementById("hero-chips").innerHTML=chips.join("");

  // ── SECCIÓN 1 — RESPONSABLE ──
  setText("tbl-nombre",    display);
  setText("tbl-esp",       especialidad);
  setText("tbl-cedula",    cedula||"No disponible");
  setText("tbl-tel",       telefono||"No disponible");
  setText("tbl-dir",       direccion||"No disponible");
  setText("tbl-horario",   horario||"No disponible");

  // ── DATOS PLATAFORMA (desde generador) ──
  setText("tbl-plat",      plataforma||"No disponible");

  // Correo de privacidad — viene en cfg.gen_correo (inyectado desde LOGIN_GENERADOR)
  var correoPriv = cfg.gen_correo||"";
  if(correoPriv){
    setHtml("tbl-correo-priv",'<a href="mailto:'+esc(correoPriv)+'">'+esc(correoPriv)+'</a>');
  } else {
    setText("tbl-correo-priv","No disponible");
  }

  // Teléfono del generador
  var telGen = cfg.gen_telefono||"";
  if(telGen){
    setHtml("tbl-plat-tel",'<a href="tel:'+esc(telGen)+'">'+esc(telGen)+'</a>');
  } else {
    setText("tbl-plat-tel","No disponible");
  }

  // Vigencia
  var hoy=new Date();
  setText("tbl-vigencia","Vigente al "+hoy.getDate()+"/"+(hoy.getMonth()+1)+"/"+hoy.getFullYear());
  setText("fecha-actualizacion","Última actualización: "+hoy.toLocaleDateString("es-MX",{year:"numeric",month:"long",day:"numeric"}));

  // ── FOOTER ──
  setText("footer-logo", plataforma||display);
  setText("footer-sub", (plataforma?"Plataforma médica verificada · ":"")+"Aviso de Privacidad");

  // ── CTA GENERADOR (para nuevos consultorios interesados) ──
  if(plataforma || telGen || correoPriv){
    var ctaEl=document.getElementById("gen-cta");
    ctaEl.style.display="block";

    // Avatar del generador
    var ctaAvatar=document.getElementById("gen-cta-avatar");
    if(cfg.gen_logo&&cfg.gen_logo.length>100){
      ctaAvatar.innerHTML='<img src="'+cfg.gen_logo+'" style="width:100%;height:100%;object-fit:cover;border-radius:50%"/>';
    } else {
      ctaAvatar.textContent=(plataforma||"P")[0].toUpperCase();
    }

    setText("gen-cta-nombre",    plataforma||"Plataforma médica");
    setText("gen-cta-nombre-footer", plataforma||"");

    // Botón WhatsApp
    var btnWA=document.getElementById("gen-btn-wa");
    if(telGen){
      var wa=telGen.replace(/\D/g,"");
      var msgWA="Hola, vi el consultorio de "+display+" y me interesa obtener mi propio consultorio digital en "+plataforma+". ¿Me puedes dar más información?";
      btnWA.href="https://wa.me/52"+wa+"?text="+encodeURIComponent(msgWA);
    } else {
      btnWA.style.display="none";
    }

    // Botón Correo
    var btnMail=document.getElementById("gen-btn-mail");
    if(correoPriv){
      var asunto="Quiero mi consultorio digital — "+plataforma;
      var cuerpo="Hola,\n\nVi el consultorio de "+display+" y me interesa obtener mi propio consultorio digital.\n\n¿Me puedes dar más información sobre planes y precios?\n\nGracias.";
      btnMail.href="mailto:"+correoPriv+"?subject="+encodeURIComponent(asunto)+"&body="+encodeURIComponent(cuerpo);
    } else {
      btnMail.style.display="none";
    }
  }
}

function mostrarError(msg){
  document.getElementById("loader").style.display="none";
  document.getElementById("main").style.display="block";
  document.querySelector(".hero-title").textContent="Error";
  document.querySelector(".hero-sub")||"";
  setText("hero-sub",msg);
  document.getElementById("gen-cta").style.display="none";
}
</script>
</body>
</html>
